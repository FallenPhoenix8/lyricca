# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://database.example.com:5432/db"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://database.example.com:5432/db"

# JWT Secret
JWT_SECRET="<TOP_SECRET>"

# Cookie Secret
COOKIE_SECRET="<TOP_SECRET>"

# Translation API Key
DEEPL_TRANSLATION_API_KEY="***************************************"

# Frontend URL
FRONTEND_URL="https://frontend.example.com"

# Supabase Secret Key
SUPABASE_SECRET_KEY="<TOP_SUPABASE_SECRET>"

# Supabase URL
SUPABASE_URL="https://<YOUR_PROJECT_ID>.supabase.co"


# SMTP Configuration
SMTP_HOST="mail.example.com"
SMTP_PORT="465"
SMTP_USER="no-reply@example.com"
SMTP_PASS="<VERY_STRONG_PASSWORD>"
FROM_EMAIL_ADDRESS="no-reply@example.com"